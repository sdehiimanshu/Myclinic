@model IEnumerable<MyClinic.Application.DTOs.AppointmentDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Appointments (Admin)";
}

<h2>Appointments (Admin)</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Department</th>
            <th>Date</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.PhoneNumber</td>
                <td>@item.Department</td>
                <td>@item.AppointmentDate.ToShortDateString()</td>
                <td>
                    <a asp-controller="Admin"
                       asp-action="EditAppointment"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-warning">
                        Edit
                    </a>
                    <form asp-controller="Admin"
                          asp-action="DeleteAppointment"
                          asp-route-id="@item.Id"
                          method="post"
                          style="display:inline;"
                          onsubmit="return confirm('Are you sure you want to delete this appointment?');">

                        <button type="submit" class="btn btn-sm btn-danger">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
