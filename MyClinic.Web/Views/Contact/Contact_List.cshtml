@model IEnumerable<MyClinic.Application.DTOs.ContactQueryDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Contact Queries";
}

<h2>Contact Queries</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Message</th>
            <th style="width:180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.PhoneNumber</td>
                <td>@item.Message</td>
                <td>
                    <!-- EDIT -->
                    <a asp-controller="Admin"
                       asp-action="EditContact"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <!-- DELETE -->
                    <form asp-controller="Admin"
                          asp-action="DeleteContact"
                          asp-route-id="@item.Id"
                          method="post"
                          style="display:inline;"
                          onsubmit="return confirm('Are you sure you want to delete this query?');">
                        <button type="submit" class="btn btn-sm btn-danger">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
